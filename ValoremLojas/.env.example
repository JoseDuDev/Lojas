# =============================================
# VALOREM LOJAS — Variáveis de Ambiente
# Copie para .env e preencha os valores reais
# =============================================

# --- Banco de Dados ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/valorem_lojas"
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=valorem_lojas

# --- Redis ---
REDIS_URL="redis://:redis123@localhost:6379"
REDIS_PASSWORD=redis123

# --- Meilisearch ---
MEILI_HOST="http://localhost:7700"
MEILI_MASTER_KEY="masterKey123"

# --- Auth ---
JWT_SECRET="seu-segredo-jwt-super-seguro"
JWT_EXPIRES_IN="7d"

# --- Plataforma de Pagamento Valorem Pay ---
# Homologação: https://external-api-homolog.checkout.valorem.com.br
# Produção:    https://external-api.checkout.valorem.com.br
PAYMENT_API_URL="https://external-api-homolog.checkout.valorem.com.br"

# Token de integração fornecido pela Valorem (informado no header Authorization: Bearer)
PAYMENT_API_KEY="seu-token-de-integracao-valorem"

# Campo "tributo" exigido pela API Valorem — confirmar valor com a Valorem
# Exemplos: "" (vazio), "MERCADORIA", "SERVICO" — depende do seu contrato
PAYMENT_TRIBUTO=""

# CNPJ do estabelecimento (usado em tokenização de cartão)
PAYMENT_CNPJ_ESTABELECIMENTO="00.000.000/0001-00"

# --- Storage (S3 / Cloudflare R2) ---
STORAGE_PROVIDER="s3"  # s3 | r2
STORAGE_BUCKET="valorem-lojas-media"
STORAGE_REGION="us-east-1"
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_CDN_URL="https://cdn.seusite.com.br"

# --- E-mail (Nodemailer SMTP) ---
# Compatível com SendGrid (host=smtp.sendgrid.net, user=apikey, pass=SG.xxx)
# Mailgun (host=smtp.mailgun.org), Resend SMTP (host=smtp.resend.com)
# Deixe MAIL_HOST vazio para desabilitar envio de e-mails
MAIL_HOST=""
MAIL_PORT=587
MAIL_USER=""
MAIL_PASS=""
MAIL_FROM="\"Nome da Loja\" <noreply@seudominio.com.br>"

# --- App ---
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
BASE_DOMAIN="valorem.lojas"  # tenants ficam em {subdomain}.valorem.lojas
